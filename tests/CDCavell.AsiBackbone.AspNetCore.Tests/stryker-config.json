{
  "stryker-config": {
    "solution": "../../AsiBackbone.slnx",
    "project": "CDCavell.AsiBackbone.AspNetCore.csproj",
    "target-framework": "net10.0",
    "configuration": "Release",
    "coverage-analysis": "off",
    "reporters": [
      "html",
      "cleartext"
    ],
    "report-file-name": "index",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "Handshakes/AsiBackboneAcknowledgmentChallenge.cs",
      "Handshakes/AsiBackboneAcknowledgmentChallengeOptions.cs",
      "Handshakes/AsiBackboneAcknowledgmentChallengeRequest.cs",
      "Handshakes/AsiBackboneAcknowledgmentChallengeResult.cs",
      "Handshakes/DefaultAsiBackboneAcknowledgmentChallengeService.cs"
    ]
  }
}
