{
  "stryker-config": {
    "solution": "AsiBackbone.slnx",
    "project": "src/CDCavell.AsiBackbone.Core/CDCavell.AsiBackbone.Core.csproj",
    "test-projects": [
      "tests/CDCavell.AsiBackbone.Core.Tests/CDCavell.AsiBackbone.Core.Tests.csproj"
    ],
    "target-framework": "net10.0",
    "configuration": "Release",
    "reporters": [
      "html",
      "cleartext"
    ],
    "report-file-name": "index",
    "output": "artifacts/mutation-report/core",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "src/CDCavell.AsiBackbone.Core/**/*.cs",
      "!src/CDCavell.AsiBackbone.Core/**/obj/**/*.cs",
      "!src/CDCavell.AsiBackbone.Core/**/bin/**/*.cs",
      "!src/CDCavell.AsiBackbone.Core/**/*.g.cs"
    ]
  }
}
